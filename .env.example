# Optional worker log level. Supported values will be validated by the worker.
VERA_LOG_LEVEL=

# Hosted development, staging, and production use PostgreSQL only.
# Keep real credentials in environment-specific secret management, never in this file.
DATABASE_URL=postgresql://vera:vera_dev_only@127.0.0.1:5432/vera
TEST_DATABASE_URL=postgresql://vera:vera_dev_only@127.0.0.1:5432/vera_test
VERA_DB_POOL_MAX=5
VERA_DB_CONNECTION_TIMEOUT_MS=5000
VERA_DB_STATEMENT_TIMEOUT_MS=15000
VERA_DB_LOCK_TIMEOUT_MS=3000
VERA_DB_IDLE_TRANSACTION_TIMEOUT_MS=10000

# Hosted identity configuration. This Google Web Application client is identity-only and
# requests openid, email, and profile. Never reuse it for Gmail or Calendar data access.
BETTER_AUTH_SECRET=
VERA_PUBLIC_BASE_URL=http://127.0.0.1:3000
VERA_AUTH_GOOGLE_CLIENT_ID=
VERA_AUTH_GOOGLE_CLIENT_SECRET=

# Optional hosted Google integration client. Configure all three together or leave all blank.
# Development, staging, and production use different Web Application clients and exact callbacks.
# Local callbacks:
# http://127.0.0.1:3000/api/integrations/google/calendar/callback
# http://127.0.0.1:3000/api/integrations/google/gmail/callback
VERA_GOOGLE_INTEGRATION_CLIENT_ID=
VERA_GOOGLE_INTEGRATION_CLIENT_SECRET=
VERA_GOOGLE_INTEGRATION_REDIRECT_URI=
VERA_GOOGLE_TIMEOUT_MS=5000

# Application-layer integration credential encryption. Supply 32-byte keys as base64.
VERA_CREDENTIAL_KEY_ID=development-1
VERA_CREDENTIAL_KEYS_JSON=

# Offline sanitized demo storage only. Normal hosted commands never read this value.
VERA_DEMO_DATA_DIR=

# Optional comma-separated exact policy kill-switch keys.
# `integrations.disabled` denies all connectors; connector-specific keys are shown on /connectors.
VERA_ACTIVE_KILL_SWITCHES=
VERA_INTEGRATIONS_DISABLED=1
VERA_GMAIL_ALERTS_DISABLED=1

# Unsupported founder-only OpenClaw current-tab capture. Leave unset/disabled by default.
# Gateway credentials are server-side only and must never use a NEXT_PUBLIC_ prefix.
# Exact founder Vera UUIDs allowed to use the experimental browser bridge.
# Missing or malformed configuration denies job creation, dispatch, and execution.
VERA_BROWSER_FOUNDER_USER_IDS=
VERA_BROWSER_DISABLED=1
# Hosted worker images set the absolute lockfile-installed path. Bare `openclaw` is local-dev only.
VERA_OPENCLAW_EXECUTABLE=openclaw
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
VERA_OPENCLAW_LIVE_TEST=0
VERA_OPENCLAW_NODE_ID=
VERA_OPENCLAW_PROFILE_ID=vera-zillow
VERA_OPENCLAW_APPROVED_ZILLOW_URL=

# Hosted Maritime execution plane. Runtime keys stay server-side and should carry only
# the provision/deploy scopes required for worker status and wake. Operator credentials
# for agent creation, secret management, or teardown are separate.
MARITIME_API_KEY=
MARITIME_API_URL=https://api.maritime.sh
VERA_MARITIME_WORKER_AGENT_ID=
VERA_MARITIME_GATEWAY_AGENT_ID=
VERA_MARITIME_ENVIRONMENT=development
VERA_OPERATOR_USER_IDS=

# Browser Web Push. The public key may be exposed by the authenticated settings page;
# the private key and application-encrypted subscription material are server-only.
NEXT_PUBLIC_VERA_VAPID_PUBLIC_KEY=
VERA_VAPID_PRIVATE_KEY=
VERA_VAPID_SUBJECT=
VERA_NOTIFICATIONS_DISABLED=1
VERA_WEB_PUSH_STAGING_TEST=0
VERA_WEB_PUSH_STAGING_SUBSCRIPTION_JSON=
VERA_MARITIME_STAGING_TEST=0

# Optional live structured extraction. Leave both values unset for deterministic-only mode.
# Supplying exactly one is a visible configuration error. Never commit a real key.
# OPENAI_API_KEY=
# VERA_LLM_MODEL=

# Optional live-provider timeout in milliseconds. Allowed range: 1000-30000.
VERA_LLM_TIMEOUT_MS=20000

# Live LLM tests run only when this is exactly 1 and both live values above are non-empty.
# Default unit, integration, E2E, and build paths make no provider request.
VERA_RUN_LIVE_LLM_TESTS=0
