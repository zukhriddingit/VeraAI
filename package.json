{
  "name": "vera",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream --filter @vera/web --filter @vera/worker run dev",
    "postgres:up": "docker compose up -d postgres",
    "postgres:down": "docker compose down",
    "postgres:reset": "tsx scripts/postgres-reset.ts",
    "postgres:backup-rehearsal": "tsx scripts/postgres-backup-rehearsal.ts --confirm vera_test",
    "verify:calendar-boundaries": "tsx scripts/verify-calendar-boundaries.ts",
    "verify:db-boundaries": "tsx scripts/verify-database-boundaries.ts",
    "verify:browser-boundaries": "tsx scripts/verify-browser-boundaries.ts",
    "verify:gmail-boundaries": "tsx scripts/verify-gmail-boundaries.ts",
    "verify:web-mutation-boundaries": "tsx scripts/verify-web-mutation-boundaries.ts",
    "verify:maritime-boundaries": "tsx scripts/verify-maritime-boundaries.ts",
    "verify:openclaw-config": "tsx scripts/verify-openclaw-config.ts",
    "verify:release-manifest": "tsx scripts/verify-release-manifest.ts",
    "verify:worker-image-boundaries": "tsx scripts/verify-worker-image-boundaries.ts",
    "verify:worker-release-workflow": "tsx scripts/verify-worker-release-workflow.ts",
    "verify:worker-release-promotion": "tsx scripts/verify-worker-release-promotion.ts",
    "verify:release-documentation": "tsx scripts/verify-release-documentation.ts",
    "maritime:validate": "node infra/maritime/validate.mjs",
    "maritime:upload-openclaw-config": "tsx scripts/maritime-upload-openclaw-config.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo": "tsx scripts/demo-start.ts",
    "serve:e2e": "pnpm -r --parallel --stream --filter @vera/web --filter @vera/worker run serve:e2e",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm -r --if-present run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:integration:postgres": "vitest run --project postgres-integration",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @vera/db run db:generate",
    "db:migrate": "pnpm --filter @vera/db run db:migrate",
    "db:seed": "pnpm --filter @vera/db run db:seed",
    "worker:health": "pnpm --filter @vera/worker run health",
    "worker:noop": "pnpm --filter @vera/worker run noop",
    "worker:run-once": "pnpm --filter @vera/worker run run-once",
    "worker:start": "pnpm --filter @vera/worker run start",
    "openclaw:version": "openclaw --version",
    "openclaw:register-node": "tsx scripts/openclaw-register-node.ts",
    "test:live:openclaw": "VERA_OPENCLAW_LIVE_TEST=1 vitest run --project unit packages/connectors/src/openclaw-current-tab.live.test.ts",
    "test:staging:maritime": "VERA_MARITIME_STAGING_TEST=1 vitest run --project unit packages/connectors/src/maritime.staging.test.ts",
    "test:staging:founder-release": "tsx scripts/staging/founder-release-smoke.ts",
    "test:staging:gateway-http": "tsx scripts/staging/gateway-http-smoke.ts",
    "test:staging:web-push": "VERA_WEB_PUSH_STAGING_TEST=1 vitest run --project unit packages/notifications/src/web-push.staging.test.ts",
    "scoring:evaluate-fixtures": "pnpm --filter @vera/scoring run evaluate:fixtures"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "0.28.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "json5": "2.2.3",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
