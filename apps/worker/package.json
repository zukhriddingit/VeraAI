    "build": "node build.mjs",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve",
    "serve:e2e": "tsx src/index.ts",
    "health": "tsx src/index.ts health",
    "noop": "tsx src/index.ts noop",
