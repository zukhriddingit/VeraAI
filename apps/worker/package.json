{
  "name": "@vera/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "serve:e2e": "node --import tsx src/index.ts",
    "health": "node --import tsx src/index.ts health",
    "noop": "node --import tsx src/index.ts noop",
    "run-once": "node --import tsx src/index.ts run-once",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vera/ai": "workspace:*",
    "@vera/connectors": "workspace:*",
    "@vera/db": "workspace:*",
    "@vera/domain": "workspace:*",
    "@vera/scoring": "workspace:*",
    "pino": "10.3.1"
  }
}
