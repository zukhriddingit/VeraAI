    "@vera/notifications": "workspace:*",
    "@vera/policy": "workspace:*",
    "@vera/scoring": "workspace:*",
    "openclaw": "2026.6.33",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "sharp": "0.35.3"
  }
