{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vera.example/schemas/maritime-release-manifest-v2.json",
  "title": "Vera founder release manifest",
  "description": "Profile-bound immutable supply-chain evidence required before a Vera founder release may be deployed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseProfile",
    "capabilities",
    "releaseCommit",
    "createdAt",
    "worker",
    "openclaw",
    "rollback"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "releaseProfile": {
      "enum": ["founder_core", "founder_browser_experimental"]
    },
    "capabilities": {
      "$ref": "#/$defs/capabilities"
    },
    "releaseCommit": {
      "$ref": "#/$defs/gitCommit"
    },
    "createdAt": {
      "$ref": "#/$defs/instant"
    },
    "worker": {
      "$ref": "#/$defs/worker"
    },
    "openclaw": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/openclaw"
        }
      ]
    },
    "rollback": {
      "$ref": "#/$defs/rollback"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "releaseProfile": {
            "const": "founder_core"
          }
        },
        "required": ["releaseProfile"]
      },
      "then": {
        "properties": {
          "capabilities": {
            "allOf": [
              {
                "$ref": "#/$defs/capabilities"
              },
              {
                "properties": {
                  "browserCapture": {
                    "const": false
                  }
                }
              }
            ]
          },
          "openclaw": {
            "type": "null"
          },
          "rollback": {
            "allOf": [
              {
                "$ref": "#/$defs/rollback"
              },
              {
                "properties": {
                  "reviewedOpenclawImage": {
                    "type": "null"
                  }
                }
              }
            ]
          }
        }
      },
      "else": {
        "properties": {
          "capabilities": {
            "allOf": [
              {
                "$ref": "#/$defs/capabilities"
              },
              {
                "properties": {
                  "browserCapture": {
                    "const": true
                  }
                }
              }
            ]
          },
          "openclaw": {
            "$ref": "#/$defs/openclaw"
          },
          "rollback": {
            "allOf": [
              {
                "$ref": "#/$defs/rollback"
              },
              {
                "properties": {
                  "reviewedOpenclawImage": {
                    "$ref": "#/$defs/imageDigest"
                  }
                }
              }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "browserCapture",
        "directCapture",
        "gmailAlerts",
        "calendar",
        "webPush",
        "maritimeWorker"
      ],
      "properties": {
        "browserCapture": {
          "type": "boolean"
        },
        "directCapture": {
          "const": true
        },
        "gmailAlerts": {
          "const": true
        },
        "calendar": {
          "const": true
        },
        "webPush": {
          "const": true
        },
        "maritimeWorker": {
          "const": true
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image",
        "sourceCommit",
        "sbomSha256",
        "provenanceVerified",
        "signatureVerified",
        "vulnerabilityReview"
      ],
      "properties": {
        "image": {
          "$ref": "#/$defs/imageDigest"
        },
        "sourceCommit": {
          "$ref": "#/$defs/gitCommit"
        },
        "sbomSha256": {
          "$ref": "#/$defs/sha256"
        },
        "provenanceVerified": {
          "const": true
        },
        "signatureVerified": {
          "const": true
        },
        "vulnerabilityReview": {
          "$ref": "#/$defs/vulnerabilityReview"
        }
      }
    },
    "openclaw": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image",
        "version",
        "upstreamCommit",
        "sbomSha256",
        "provenanceVerified",
        "signatureVerified",
        "vulnerabilityReview"
      ],
      "properties": {
        "image": {
          "const": "ghcr.io/openclaw/openclaw@sha256:99546785a121ccac065263d4b609c3dc08a396d260b20c837722e7998be0a6ee"
        },
        "version": {
          "const": "2026.6.33"
        },
        "upstreamCommit": {
          "const": "7af0cfc"
        },
        "sbomSha256": {
          "$ref": "#/$defs/sha256"
        },
        "provenanceVerified": {
          "const": true
        },
        "signatureVerified": {
          "const": true
        },
        "vulnerabilityReview": {
          "$ref": "#/$defs/vulnerabilityReview"
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewedWorkerImage",
        "reviewedOpenclawImage",
        "workerSchemaCompatible",
        "workerCompatibilityEvidenceSha256"
      ],
      "properties": {
        "reviewedWorkerImage": {
          "$ref": "#/$defs/imageDigest"
        },
        "reviewedOpenclawImage": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/imageDigest"
            }
          ]
        },
        "workerSchemaCompatible": {
          "const": true
        },
        "workerCompatibilityEvidenceSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "instant": {
      "type": "string",
      "format": "date-time"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "not": {
        "pattern": "^0{64}$"
      }
    },
    "imageDigest": {
      "type": "string",
      "pattern": "^[^\\s@]+@sha256:[a-f0-9]{64}$",
      "not": {
        "pattern": "@sha256:0{64}$"
      }
    },
    "vulnerabilityReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "highAccepted", "scanner", "databaseUpdatedAt", "scannedAt"],
      "properties": {
        "critical": {
          "const": 0
        },
        "highAccepted": {
          "const": 0
        },
        "scanner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": ".*\\S.*"
        },
        "databaseUpdatedAt": {
          "$ref": "#/$defs/instant"
        },
        "scannedAt": {
          "$ref": "#/$defs/instant"
        }
      }
    }
  }
}
